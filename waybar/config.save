{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 50,
    "spacing": 14,
    "modules-left": ["hyprland/workspaces", "mpris"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["clock"],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 5
        }
    },

    "mpris": {
        "format": "{player_icon} {status_icon} {dynamic}",
        "format-paused": "{player_icon} {status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "<span>󰎈</span>",
            "firefox": "<span></span>",
            "spotify": "<span></span>"
        },
        "status-icons": {
            "playing": "<span>󰏤</span>",
            "paused": "<span>󰐊</span>"
        },
        "max-length": 10
    },

    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true,
        "max-length": 20
    },

    "clock": {
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }
}
