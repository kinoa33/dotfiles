/* Import the pywal generated colors */
@import "../../.cache/wal/colors-waybar.css";

* {
    border: none;
    border-radius: 16px;
    font-family: "SF Pro Display", "monospace";
    font-size: 16px;
    min-height: 0;
}

window#waybar {
    background-color: rgba(0, 0, 0, 0.5);
    color: @foreground;
    border: 1px solid @color1;
    /* This adds the gap from the top you wanted */
    margin: 8px 10px;
    padding: 6px }22px;
}

/* ---Workspaces (Purple/Accent Glow) --- */
#workspaces button {
    padding: 0 8px;
    color: @color5;
    text-shadow: 0 0 5px @color5, 0 0 10px @color5, 0 0 20px rgba(189, 147, 249, 0.9);
    transition: all 0.3s ease;
}

#workspaces button.active {
    color: @foreground;
    text-shadow: 0 0 8px @foreground, 0 0 15px @color5, 0 0 25px @color5;
    border-bottom: 2px solid @color5;
}

/* --- Media Player (Gold Glow) --- */
#mpris {
    color: @color3;
    text-shadow: 0 0 5px @color3, 0 0 15px rgba(241, 250, 140, 0.6);
    padding: 0 10px;
    margin-left: 10px;
}

/* --- Window Title (White Glow) --- */
#window {
    color: @foreground;
    text-shadow: 0 0 5px @foreground, 0 0 10px rgba(248, 248, 242, 0.5);
    font-weight: bold;
}

/* --- Clock (Cyan Glow) --- */
#clock {
    color: @color6;
    text-shadow: 0 0 5px @color6, 0 0 15px @color6, 0 0 20px rgba(139, 233, 253, 0.6);
    padding: 0 15px;
}
