@import "../../.cache/wal/colors-waybar.css";

* {
    border: none;
    border-radius: 12px;
    font-family: "SF Pro Display", "monospace";
    font-size: 14px;
    min-height: 0;
}

window#waybar {
    background-color: rgba(0, 0, 0, 0.75);
    color: @foreground;
    border: 1px solid @color5;
    margin: 15px 10px;
}

/* --- Tighter Spacing --- */
#workspaces, #mpris, #window, #pulseaudio, #clock, #custom-notification {
    padding-top: 12px;
    padding-bottom: 12px;
    margin: 0 6px;
}

/* --- Workspaces --- */
#workspaces button {
    padding: 0 6px;
    color: @color5;
    text-shadow: 0 0 5px @color5;
    transition: all 0.3s ease;
}

#workspaces button.active {
    color: @foreground;
    text-shadow: 0 0 8px @foreground, 0 0 15px @color5;
    border-bottom: 2px solid @color5;
}

/* --- Notification Bell --- */
#custom-notification {
    color: @color2;
    text-shadow: 0 0 5px @color2, 0 0 10px @color2;
    padding: 0 10px;
    font-size: 20px;
}

/* --- Colors & Glows --- */
#mpris { color: @color3; text-shadow: 0 0 5px @color3; }
#window { font-weight: bold; color: @foreground; }
#pulseaudio { color: @color4; text-shadow: 0 0 5px @color4; }
#clock { color: @color6; text-shadow: 0 0 5px @color6; font-weight: bold; }
